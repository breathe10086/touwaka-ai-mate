{
  "id": "ocr-tool",
  "name": "OCR 文字识别工具",
  "version": "2.0.0",
  "description": "上传图片，使用多模态模型识别文字内容，不保存原图。",
  "icon": "📝",
  "type": "utility",
  "author": "Touwaka Team",
  "license": "MIT",
  "keywords": ["OCR", "图片", "VLM", "文字识别"],
  "compatibility": {
    "min_platform_version": "2.0.0"
  },
  "config": {
    "max_concurrent_tasks": 2,
    "max_image_size_bytes": 8388608,
    "vlm_model_id": "mpaypmqx4oh81qhbdcdc",
    "vlm_prompt": "请识别图片中的所有文字内容，保持原有的格式和排版。如果图片中没有文字，请回复\"图片中未检测到文字\"。",
    "vlm_temperature": 0.2,
    "vlm_timeout_ms": 120000
  },
  "states": [
    {
      "name": "pending",
      "label": "待处理",
      "sort_order": 1,
      "is_initial": true,
      "is_terminal": false,
      "is_error": false,
      "handler": null,
      "success_next": "processing",
      "failure_next": "error"
    },
    {
      "name": "processing",
      "label": "处理中",
      "sort_order": 2,
      "is_initial": false,
      "is_terminal": false,
      "is_error": false,
      "handler": null,
      "success_next": "done",
      "failure_next": "error"
    },
    {
      "name": "done",
      "label": "已完成",
      "sort_order": 3,
      "is_initial": false,
      "is_terminal": true,
      "is_error": false,
      "handler": null,
      "success_next": null,
      "failure_next": null
    },
    {
      "name": "error",
      "label": "失败",
      "sort_order": 99,
      "is_initial": false,
      "is_terminal": false,
      "is_error": true,
      "handler": null,
      "success_next": null,
      "failure_next": null
    }
  ],
  "component": "OcrToolView",
  "visibility": "all"
}
